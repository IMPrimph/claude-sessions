{
  "$schema": "https://raw.githubusercontent.com/nicholasio/tauri-apps-tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "Claude Sessions",
  "version": "0.4.3",
  "identifier": "com.claude-sessions.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Sessions",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://github.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.claude/image-cache/**",
          "$HOME/**/*.png",
          "$HOME/**/*.jpg",
          "$HOME/**/*.jpeg",
          "$HOME/**/*.gif",
          "$HOME/**/*.webp"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/IMPrimph/claude-sessions/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2MDNFNUUxQTE5MkJBNDAKUldSQXVwS2g0ZVVEZHArNEFjbUc1TVJqTzJqRGZ0S3BjeWhDMVA0WUJNRkhkZWd3WjdzeS80MjkK"
    }
  }
}
